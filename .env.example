# --- CONFIGURACIÓN DE RED ---
PORT=3000

# --- SUPABASE (Base de Datos y RLS) ---
# URL de tu proyecto de Supabase (ej: https://xyz.supabase.co)
SUPABASE_URL=
# Service Role Key (secret) para bypass de RLS en el backend
SUPABASE_SERVICE_KEY=

# --- IA (Google Gemini) ---
# Tu API Key de Google AI Studio
GOOGLE_GENERATIVE_AI_API_KEY=
# Modelo recomendado para velocidad y costo
GEMINI_MODEL=gemini-2.0-flash-exp

# --- WHATSAPP (Kapso API) ---
# URL de la API de Kapso (ej: https://api.kapso.io/v1)
KAPSO_API_URL=
# Token de autenticación de Kapso
KAPSO_API_TOKEN=
# Secreto para validar que los webhooks vienen de Kapso
KAPSO_WEBHOOK_SECRET=

# --- SOPORTE Y ALERTAS ---
# Número E.164 (sin +) para recibir errores críticos (ej: 573117391515)
SUPPORT_PHONE_NUMBER=

# --- LOGS Y BUFFER ---
# Nivel de logs a persistir en BD (DEBUG, INFO, WARN, ERROR, CRITICAL)
LOG_PERSIST_LEVEL=INFO
# Tamaño del lote para insertar logs en Supabase
LOG_BATCH_SIZE=50
# Ventana de tiempo (ms) para agrupar notificaciones de error repetidas
SUPPORT_NOTIFY_WINDOW_MS=300000

# --- GOOGLE CALENDAR (opcional — activa agendamiento vía GCal) ---
# JSON completo del service account de Google Cloud (en una sola línea).
# Onboarding: las clínicas deben compartir su Google Calendar con client_email.
# En Railway: pegar el JSON raw como variable de entorno.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Email del service account — mostrar a clínicas durante el onboarding.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Cuántos días hacia adelante buscar disponibilidad (default: 14)
GCAL_LOOK_AHEAD_DAYS=14

# --- GOOGLE CALENDAR (OAuth 2.0 — permisos delegados por el staff) ---
# Credenciales OAuth de tipo "Web application" del mismo proyecto de Google Cloud.
# El staff autoriza al sistema vía link para que cree citas a su nombre.
# Client ID y Secret generados en Google Cloud Console → APIs & Services → Credentials.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# URI de redirección registrada en Google Cloud Console (debe coincidir exactamente).
# Ejemplo: https://tu-dominio.railway.app/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
