# Variables de entorno para el portal web (Next.js en Vercel)
# Configurar en: Vercel Dashboard → Project Settings → Environment Variables

# Supabase — usar el mismo proyecto que el backend de Railway
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NOTA: SUPABASE_SERVICE_KEY se usa SOLO en Server Components (nunca se expone al browser).
# Nunca usar NEXT_PUBLIC_ con la service key.

# Auth — debe coincidir exactamente con INTERNAL_API_SECRET del backend
INTERNAL_API_SECRET=

# Backend — URL interna para disparar rebuild-prompt tras guardar (opcional)
BACKEND_INTERNAL_URL=https://tu-backend.railway.app
